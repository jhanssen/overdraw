{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2024"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "verbatimModuleSyntax": false,
    "types": ["node", "@webgpu/types"],
    "paths": {
      "#protocols-gen/*": ["./dist/protocols-gen/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
