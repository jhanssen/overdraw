{
  "name": "overdraw",
  "version": "0.0.0",
  "private": true,
  "description": "Wayland compositor: thin C++ core + Node, separate native GPU process (Dawn).",
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#protocols-gen/*": "./dist/protocols-gen/*"
  },
  "scripts": {
    "start": "npm run build:js && node dist/index.js",
    "compositor": "npm run build:js && node dist/main.js",
    "gen-protocols": "node tools/gen-protocol/gen-protocol.js",
    "build:js": "npm run gen-protocols && tsc",
    "test": "npm run build:js && node --test 'test/**/*.test.js'",
    "test:gpu": "npm run build:js && node --test --test-concurrency=1 'test/*.gpu.mjs'"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "@webgpu/types": "^0.1.70",
    "typescript": "^6.0.3"
  }
}
