{
  "name": "overdraw-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Wayland compositor: thin C++ core + Node, separate native GPU process (Dawn). Workspace root.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm run build:js && node packages/core/dist/index.js",
    "compositor": "npm run build:js && node packages/core/dist/main.js",
    "gen-protocols": "npm run gen-protocols -w overdraw",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "build:js": "npm run gen-protocols && tsc -b && npm run lint",
    "test": "npm run build:js && node --test 'test/**/*.test.js'",
    "test:gpu": "npm run build:js && node --test --test-concurrency=1 'test/*.gpu.mjs'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.19",
    "@webgpu/types": "^0.1.70",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
