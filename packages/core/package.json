{
  "name": "overdraw",
  "version": "0.0.0",
  "private": true,
  "description": "Wayland compositor: thin C++ core + Node, separate native GPU process (Dawn).",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    }
  },
  "imports": {
    "#protocols-gen/*": "./dist/protocols-gen/*"
  },
  "bin": {
    "overdrawctl": "./bin/overdrawctl"
  },
  "scripts": {
    "gen-protocols": "node tools/gen-protocol/gen-protocol.js",
    "build:js": "npm run gen-protocols && tsc -b"
  }
}
