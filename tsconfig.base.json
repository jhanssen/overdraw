{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2024"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": false,
    "verbatimModuleSyntax": false,
    "composite": true,
    "types": ["node", "@webgpu/types"]
  }
}
